<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- HOME SCREEN -->
    <ScrollView
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz &amp; Flashcards"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test yourself with AI-generated quizzes"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Quiz"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Generate a multiple-choice quiz based on your notes. Tests retention and understanding."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartQuiz"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Quiz"
                        app:icon="@drawable/ic_quiz"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResumeQuiz"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Resume Quiz"
                        android:visibility="gone"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flashcards"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI-generated flashcards from your notes. Tap to flip and see the answer."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFlashcards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Study Flashcards"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent History"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvHistoryEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No quizzes taken yet. Start your first quiz!"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvHistoryItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- LOADING SCREEN -->
    <LinearLayout
        android:id="@+id/loadingScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminate="true"
            android:layout_marginBottom="16dp"/>
        <TextView
            android:id="@+id/tvLoadingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="@color/text_primary"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- QUIZ SCREEN -->
    <ScrollView
        android:id="@+id/quizScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <ProgressBar
                android:id="@+id/quizProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="10"
                android:progress="1"
                android:layout_marginBottom="8dp"
                android:progressTint="@color/primary"/>
            <TextView
                android:id="@+id/tvQuestionNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 of 10"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">
                <TextView
                    android:id="@+id/tvQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Question"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="A"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="B"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="C"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:text="D"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp"/>
            <TextView
                android:id="@+id/tvAnswerFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Next Question"
                android:visibility="gone"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveExitQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Save &amp; Exit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- RESULTS SCREEN -->
    <LinearLayout
        android:id="@+id/resultsScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quiz Complete!"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/tvResultPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80%"
            android:textColor="@color/primary"
            android:textSize="56sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvResultScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8 / 10"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/tvResultMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Great job!"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetryQuiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Try Again"
            app:cornerRadius="12dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuitQuiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- FLASHCARD SCREEN -->
    <LinearLayout
        android:id="@+id/flashcardScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flashcards"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/tvCardCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 5"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/flashcard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/card_background">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:id="@+id/tvCardFace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Flashcard text"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp"/>
                <TextView
                    android:id="@+id/tvCardHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap card to reveal answer"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Previous"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Next"
                app:cornerRadius="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDoneFlashcards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                style="@style/Widget.Material3.Button.TextButton"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
