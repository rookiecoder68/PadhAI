# select which backend to use: 'azure' (default) or 'hf' (HuggingFace) or 'google'
MODEL_PROVIDER=google

# Azure OpenAI (used when MODEL_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://padhai-openai-eastus2.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
OPENAI_DEPLOYMENT_NAME=gpt-4o

# Hugging Face (used when MODEL_PROVIDER=hf)
HF_API_KEY=your_hugging_face_api_key_here
# a model that you can call via inference API; small ones are free, examples:
#   gpt2
#   meta-llama/Llama-2-7b-chat-hf
HF_MODEL=gpt2

# Google GenAI (used when MODEL_PROVIDER=google)
# Get your free API key from: https://ai.google.dev/
# same key works for GenAI and Text-to-Speech (AI Studio/Vertex AI)
GOOGLE_API_KEY=your_google_api_key_here
# optional model override, defaults to text-bison-001
GOOGLE_MODEL=text-bison-001

# Azure Speech (optional, for Text-to-Speech)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=koreacentral

# Azure Computer Vision (optional, for OCR)
AZURE_CV_KEY=your_azure_cv_key_here
AZURE_CV_REGION=eastus
